# Golden Goose Tees - Environment Variables
# Copy this file to .env.local for local development
# All VITE_ prefixed vars are exposed to the client

# ===========================================
# SUPABASE
# ===========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (Vercel functions) - DO NOT prefix with VITE_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# STRIPE
# ===========================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
VITE_STRIPE_TEST_MODE=true

# Server-side only (Vercel functions) - DO NOT prefix with VITE_
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ===========================================
# PRINTFUL (Server-side only - DO NOT prefix with VITE_)
# ===========================================
# Printful API keys are server-only for security
PRINTFUL_API_KEY=your-printful-api-key
PRINTFUL_STORE_ID=optional-store-id

# Optional: Allow mock orders in development (default: false)
# ALLOW_PRINTFUL_MOCK_ORDERS=false

# ===========================================
# AI SERVICES (Server-side only - DO NOT prefix with VITE_)
# ===========================================
# OpenRouter for conversational AI (when enabled in admin)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Gemini for primary chat and image generation (server-side; Nano-Banana style)
GEMINI_API_KEY=your-gemini-api-key

# OpenAI for chat and image fallback (when Gemini fails or is unset)
OPENAI_API_KEY=sk-your-openai-key

# Optional: expose Gemini key to client for legacy/other use (prefer server-side GEMINI_API_KEY)
# VITE_GEMINI_API_KEY=your-gemini-api-key

# Background removal: set REMOVE_BG_API_KEY (recommended) or REPLICATE_API_TOKEN
# REMOVE_BG_API_KEY=your-remove-bg-api-key
# REPLICATE_API_TOKEN=your-replicate-api-token

# ===========================================
# AWS BEDROCK (Server-side only - DO NOT prefix with VITE_)
# ===========================================
# AWS credentials for Bedrock access
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Optional: If using temporary credentials or AWS SSO
# AWS_SESSION_TOKEN=your-session-token

# Bedrock model configuration
# Available Claude models: anthropic.claude-3-5-sonnet-20241022-v2:0, anthropic.claude-3-opus-20240229, etc.
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ===========================================
# MAILJET (Admin alerts: email + SMS)
# ===========================================
# Email: https://dev.mailjet.com/guides/send-api-v31/
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_SECRET_KEY=your-mailjet-secret-key
MAILJET_EMAIL_FROM=alerts@yourdomain.com

# SMS: https://dev.mailjet.com/guides/sms/
MAILJET_SMS_TOKEN=your-mailjet-sms-token
MAILJET_SMS_FROM=GoldenGoose

# ===========================================
# APP CONFIG
# ===========================================
# For local development, use: http://localhost:5173
# For production deployment, use: https://goldengoosetees.com
VITE_APP_URL=http://localhost:5173

# When using `npm run dev` + `vercel dev` on another port, Vite proxies /api here (default http://127.0.0.1:3000)
# VITE_DEV_API_PROXY=http://127.0.0.1:3000

# ===========================================
# PRICING V2 + FULFILLMENT (optional rollout)
# ===========================================
# Server (Vercel): enable quote API + server order creation
# PRICING_V2_ENABLED=true
# DYNAMIC_SHIPPING_ENABLED=true
# SERVER_FULFILLMENT_ENABLED=true
# CRON_SECRET=random-long-secret-for-variant-cache-cron

# Client (Vite): must mirror server flags you enable
# VITE_PRICING_V2_ENABLED=true
# VITE_SERVER_FULFILLMENT_ENABLED=true

# Optional: comma-separated Printful catalog product IDs; overrides repo defaults (Vercel: use this to change live offerings)
# PRINTFUL_CURATED_PRODUCT_IDS=71,12,145,146,206,100,81,19,1
