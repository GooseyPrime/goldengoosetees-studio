{
    "compilerOptions": {
        "target": "ES2020",
        "module": "preserve",
        "moduleResolution": "bundler",
        "lib": ["ES2020"],
        "skipLibCheck": true,
        "noEmit": true,
        "paths": {
            "#api/*": ["./_lib/*"]
        },
        "baseUrl": "."
    },
    "include": ["./**/*.ts"]
}
